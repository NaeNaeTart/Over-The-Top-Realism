<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net46</TargetFramework>
    <AssemblyName>OverTheTopRealism</AssemblyName>
    <RootNamespace>OverTheTopRealism</RootNamespace>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Output directly into the plugins folder so the game picks it up automatically -->
    <OutputPath>$(MSBuildProjectDirectory)\..\..\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
    <Description>Over-the-top Realism mod for Casualties: Unknown. Adds deep physiological, trauma, and hemodynamics simulation.</Description>
  </PropertyGroup>

  <!-- ─────────── BepInEx core references ─────────── -->
  <ItemGroup>
    <Reference Include="BepInEx">
      <HintPath>..\..\..\core\BepInEx.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="0Harmony">
      <HintPath>..\..\..\core\0Harmony.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <!-- ─────────── Unity Engine references ─────────── -->
  <ItemGroup>
    <Reference Include="UnityEngine">
      <HintPath>..\..\..\..\CasualtiesUnknown_Data\Managed\UnityEngine.dll</HintPath>
      <Private>false</Private>
    </Reference>
